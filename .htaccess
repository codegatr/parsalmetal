Options -Indexes
Options -MultiViews
ServerSignature Off

RewriteEngine On

# HTTPS yonlendirme (aktif etmek icin yorum kaldir)
# RewriteCond %{HTTPS} off
# RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# www yonlendirme
# RewriteCond %{HTTP_HOST} ^(?!www\.)(.+)$ [NC]
# RewriteRule ^ https://www.%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Admin dizinini koru
<FilesMatch "^(config\.php|\.htaccess|\.git)">
  Order allow,deny
  Deny from all
</FilesMatch>

# Install dizinini engelle (kurulum sonrasi)
# RewriteRule ^install/ - [F,L]

# PHP dosyalari dogrudan erisimi engelle (belirtilen disinda)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ /index.php?page=$1 [L,QSA]

# Guvenlik headerlari
<IfModule mod_headers.c>
  Header always set X-Content-Type-Options nosniff
  Header always set X-Frame-Options SAMEORIGIN
  Header always set X-XSS-Protection "1; mode=block"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# Gzip sikistirma
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css text/javascript application/javascript
</IfModule>

# Cache - statik dosyalar
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/jpg "access plus 1 month"
  ExpiresByType image/jpeg "access plus 1 month"
  ExpiresByType image/png "access plus 1 month"
  ExpiresByType image/webp "access plus 1 month"
  ExpiresByType text/css "access plus 1 week"
  ExpiresByType application/javascript "access plus 1 week"
</IfModule>
