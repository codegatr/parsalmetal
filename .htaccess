Options -Indexes
ServerSignature Off

RewriteEngine On

# Admin ve install dizinlerini koru - önce bunlar
RewriteRule ^admin(/.*)?$ - [L]
RewriteRule ^install(/.*)?$ - [L]
RewriteRule ^assets(/.*)?$ - [L]
RewriteRule ^update(/.*)?$ - [L]

# Mevcut gerçek dosya/dizinleri atla
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

# Temiz URL: /urunler → /?page=urunler
RewriteRule ^([a-z0-9_-]+)/?$ /index.php?page=$1 [L,QSA]

# config.php doğrudan erişimi engelle
<FilesMatch "^config\.php$">
  Order allow,deny
  Deny from all
</FilesMatch>

<IfModule mod_headers.c>
  Header always set X-Content-Type-Options nosniff
  Header always set X-Frame-Options SAMEORIGIN
</IfModule>

<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css text/javascript application/javascript
</IfModule>

<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/jpeg "access plus 1 month"
  ExpiresByType image/png  "access plus 1 month"
  ExpiresByType image/webp "access plus 1 month"
  ExpiresByType text/css   "access plus 1 week"
  ExpiresByType application/javascript "access plus 1 week"
</IfModule>
